<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Formulaire Save</title>
</head>
<body>
    <h2>Formulaire (Map injection)</h2>
    <form action="save" method="POST">
        <label>Nom : <input name="nom"></label><br><br>
        <label>Prenom : <input name="prenom"></label><br><br>
        <label>Email : <input name="email"></label><br><br>
        <label>Age : <input name="age" type="number"></label><br><br>
        <button type="submit">Submit</button>
    </form>
</body>
</html>
